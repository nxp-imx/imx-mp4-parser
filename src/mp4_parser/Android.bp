cc_library_shared {
    name: "lib_mp4_parser_arm11_elinux.3.0",

    srcs: [
        "lib/src/*.c",
    ],

    local_include_dirs: [
        "lib/inc",
    ],

    cflags: [
        "-DCORE_PARSER_PARSE_H264_DEC_SPECIFIC_INFO",
    ],

    static_libs: [
        "lib_h264_parser_arm11_elinux",
        "lib_id3_parser_arm11_elinux",
    ],

    defaults: [
        "imx_parser_defaults",
    ],

    relative_install_path: "extractors",
}
